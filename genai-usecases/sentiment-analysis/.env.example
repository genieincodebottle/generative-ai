# ===========================
# LLM Provider Configuration
# ===========================

# Primary Provider: Groq (Free tier - Recommended for beginners)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Secondary Provider: Google Gemini
# Get your API key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Provider Selection: "groq" (default) or "gemini"
LLM_PROVIDER=groq

# Model Selection (optional - defaults shown)
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-2.0-flash

# Temperature: 0.0 = deterministic, 1.0 = creative (default: 0.0)
LLM_TEMPERATURE=0.0

# ===========================
# Database Configuration
# ===========================
DB_PATH=sentiment_analysis.db
