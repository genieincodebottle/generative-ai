# ---- LLM Provider ----
# Choose which LLM to use: "groq" (primary/free) or "gemini" (secondary/free)
LLM_PROVIDER="groq"

# ---- Groq API Key (Primary - Free) ----
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY="XXXXXX"

# ---- Google Gemini API Key (Secondary - Free) ----
# Get your free API key at: https://aistudio.google.com/app/apikey
# Only needed if LLM_PROVIDER="gemini"
GOOGLE_API_KEY="XXXXXX"

# ---- MongoDB ----
# Keep it same as below (Docker internal connection)
MONGODB_URI="mongodb://mongo:27017/"

# ---- Secret Key ----
# Generate using: python secret_key_generation.py
# Copy the output and paste here
SECRET_KEY="XXXXXXX"
