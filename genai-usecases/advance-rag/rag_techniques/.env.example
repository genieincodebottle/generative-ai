# Option 1 — Google Gemini (default provider)
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Option 2 — Groq (alternative provider, free open-source LLMs)
# Get a free key at https://console.groq.com/keys
# Note: Groq does not provide embedding models; HuggingFace embeddings are used automatically when Groq is selected.
GROQ_API_KEY=your_groq_api_key_here